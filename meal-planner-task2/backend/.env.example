DYNAMODB_TABLE_MAIN=trainee-2026-rifat-mhp-v2
NODE_ENV=development
PORT=3000
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Discord bot public key (from Discord Developer Portal > General Information)
DISCORD_PUBLIC_KEY=your-discord-public-key

# Discord role snowflake IDs — map Discord server roles to app roles
# Leave unset if you don't use that role in your server
DISCORD_ROLE_ADMIN=your-admin-role-id
DISCORD_ROLE_LEAD=your-lead-role-id
DISCORD_ROLE_LOGISTICS=your-logistics-role-id

# Discord webhook URL for the daily headcount report (cron Lambda)
# Create via: Channel Settings → Integrations → Webhooks → New Webhook → Copy URL
HEADCOUNT_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# CORS — only needed for local dev server (not used in Lambda)
CORS_ORIGIN=http://localhost:3000

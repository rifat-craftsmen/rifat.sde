DYNAMODB_TABLE_MAIN=mealPlanner
DYNAMODB_TABLE_SCHEDULES=mealSchedules
DYNAMODB_TABLE_TEAMS=teams
DYNAMODB_TABLE_WFH=globalWfhPeriods
NODE_ENV=development
PORT=3000
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Discord bot public key (from Discord Developer Portal > General Information)
DISCORD_PUBLIC_KEY=your-discord-public-key

# Discord role snowflake IDs — map Discord server roles to app roles
# Leave unset if you don't use that role in your server
DISCORD_ROLE_ADMIN=your-admin-role-id
DISCORD_ROLE_LEAD=your-lead-role-id
DISCORD_ROLE_LOGISTICS=your-logistics-role-id

# CORS — only needed for local dev server (not used in Lambda)
CORS_ORIGIN=http://localhost:3000

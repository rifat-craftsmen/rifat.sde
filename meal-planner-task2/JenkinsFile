pipeline {
    agent any

    environment {
        AWS_ACCESS_KEY_ID           = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY       = credentials('aws-secret-access-key')
        AWS_DEFAULT_REGION          = 'ap-southeast-1'
        TF_VAR_discord_public_key       = credentials('TF_VAR_discord_public_key')
        TF_VAR_google_chat_app_id       = credentials('TF_VAR_google_chat_app_id')
        TF_VAR_discord_webhook_url      = credentials('TF_VAR_discord_webhook_url')
        TF_VAR_google_chat_webhook_url  = credentials('TF_VAR_google_chat_webhook_url')
        TF_VAR_dynamodb_table_name      = credentials('TF_VAR_dynamodb_table_name')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Backend') {
            steps {
                dir('meal-planner-task2/backend') {
                    sh 'npm ci'
                    sh 'npm run build'
                }
            }
        }

        stage('Terraform Init') {
            steps {
                dir('meal-planner-task2/terraform') {
                    sh 'terraform init -reconfigure'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('meal-planner-task2/terraform') {
                    sh 'terraform plan -out=tfplan'
                }
            }
        }

        stage('Approval') {
            steps {
                input message: 'Proceed with deployment?', ok: 'Deploy'
            }
        }

        stage('Terraform Apply') {
            steps {
                dir('meal-planner-task2/terraform') {
                    sh 'terraform apply -auto-approve tfplan'
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}
